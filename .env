# 🔒 .env.example - Copy this to .env and fill in your real values!
# NEVER commit your real .env file to GitHub!
# Add .env to your .gitignore file!

# ==================== DATABASE ====================
# Get this from AWS RDS after you create a PostgreSQL database
DATABASE_URL=postgresql://myuser:mypassword@mydb.us-east-1.rds.amazonaws.com:5432/aiplatform

# ==================== SECURITY ====================
# Generate a random secret key:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-random-key-here-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== AI KEYS ====================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ==================== AWS ====================
# Create an IAM user in AWS Console with S3 permissions
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET_NAME=my-ai-platform-files

# ==================== STRIPE ====================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create prices in Stripe Dashboard → Products
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ==================== EMAIL ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=noreply@yourplatform.com

# ==================== APP ====================
APP_NAME=My AI Platform
MAX_FILE_SIZE_MB=50
FREE_TIER_MESSAGES=10
ALLOWED_ORIGINS=http://localhost:3000,https://yourplatform.com
